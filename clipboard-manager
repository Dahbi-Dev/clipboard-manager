def _clamp(value, lo, hi):
    return max(lo, min(value, hi))


class ClipboardManager:
    def __init__(self):
        os.makedirs(os.path.dirname(HISTORY_FILE), exist_ok=True)
        self.history = self._load()
        self.last_text = None
        self.visible = False
        self._dialog_open = False

        self._init_css()
        self._build_win()
        self._build_tray()

        self.clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        GLib.timeout_add(POLL_MS, self._poll)

        threading.Thread(target=self._hotkey_loop, daemon=True).start()

    # ── persistence ──────────────────────────────────────────────────────────

    def _load(self):
        try:
            with open(HISTORY_FILE, encoding='utf-8') as f:
                raw = json.load(f)
            return [{'text': h['text'], 'pinned': h.get('pinned', False)}
                    for h in raw if h.get('text')]
        except Exception:
            return []

    def _save(self):
        try:
            with open(HISTORY_FILE, 'w', encoding='utf-8') as f:
                json.dump(self.history, f, indent=2, ensure_ascii=False)
        except Exception:
            pass

    # ── clipboard polling ────────────────────────────────────────────────────

    def _poll(self):
        try:
            text = self.clipboard.wait_for_text()
            if text and text != self.last_text:
                self.last_text = text
                self._push(text)
        except Exception:
            pass
        return True

    def _push(self, raw):
        text = raw.strip()
        if not text:
            return
        self.history = [h for h in self.history if h['text'] != text]
        self.history.insert(0, {'text': text, 'pinned': False})
        pinned = [h for h in self.history if h['pinned']]
        unpinned = [h for h in self.history if not h['pinned']][:MAX_UNPINNED]
        self.history = pinned + unpinned
        self._save()
        if self.visible:
            GLib.idle_add(self._refresh)

    # ── UI build ─────────────────────────────────────────────────────────────

    def _init_css(self):
        p = Gtk.CssProvider()
        p.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), p,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

    def _build_win(self):
        self.win = Gtk.Window()
        self.win.set_name("clip-win")
        self.win.set_title("Clipboard History")
        self.win.set_default_size(480, 560)
        self.win.set_keep_above(True)
        self.win.set_skip_taskbar_hint(True)
        self.win.set_skip_pager_hint(True)
        self.win.set_type_hint(Gdk.WindowTypeHint.UTILITY)
        self.win.connect("delete-event", lambda w, e: self._hide() or True)
        self.win.connect("key-press-event", self._on_key)
        self.win.connect("focus-out-event", lambda w, e: (not self._dialog_open) and (self._hide() or False))

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.win.add(root)

        hdr = Gtk.Label(
            label="Clipboard History    Win+V toggle  |  Copy = copy only  |  Paste = copy+paste  |  Esc close"
        )
        hdr.set_name("header")
        hdr.set_xalign(0)
        root.pack_start(hdr, False, False, 0)

        search_wrap = Gtk.Box()
        search_wrap.set_margin_start(10)
        search_wrap.set_margin_end(10)
        search_wrap.set_margin_top(8)
        search_wrap.set_margin_bottom(4)
        self.search = Gtk.SearchEntry()
        self.search.set_name("search-entry")
        self.search.set_placeholder_text("Search clipboard history...")
        self.search.connect("search-changed", lambda e: self._refresh(e.get_text()))
        search_wrap.pack_start(self.search, True, True, 0)
        root.pack_start(search_wrap, False, False, 0)

        sw = Gtk.ScrolledWindow()
        sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.BROWSE)
        self.listbox.connect("row-activated", self._on_activate)
        sw.add(self.listbox)
        root.pack_start(sw, True, True, 0)

        # Add-item panel (hidden after win.show_all via __do_show)
        self.add_panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        self.add_panel.set_name("add-panel")

        add_lbl = Gtk.Label(label="New item")
        add_lbl.set_xalign(0)
        add_lbl.get_style_context().add_class("type-lbl")
        self.add_panel.pack_start(add_lbl, False, False, 0)

        add_scroll = Gtk.ScrolledWindow()
        add_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        add_scroll.set_min_content_height(70)
        add_scroll.set_max_content_height(120)
        self.add_view = Gtk.TextView()
        self.add_view.set_name("add-view")
        self.add_view.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        self.add_view.get_buffer().connect("changed", self._on_add_text_changed)
        add_scroll.add(self.add_view)
        self.add_panel.pack_start(add_scroll, False, False, 0)

