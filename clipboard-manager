        self.save_btn = Gtk.Button(label="Save")
        self.save_btn.set_name("save-btn")
        self.save_btn.set_sensitive(False)
        self.save_btn.connect("clicked", lambda b: self._save_new_item())
        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.set_name("cancel-add-btn")
        cancel_btn.connect("clicked", lambda b: self._hide_add_panel())
        add_btns.pack_end(self.save_btn, False, False, 0)
        add_btns.pack_end(cancel_btn, False, False, 0)
        self.add_panel.pack_start(add_btns, False, False, 0)

        root.pack_start(self.add_panel, False, False, 0)

        footer = Gtk.Box(spacing=8)
        footer.set_name("footer")
        footer.set_margin_start(10)
        footer.set_margin_end(10)
        footer.set_margin_top(4)
        footer.set_margin_bottom(6)

        self.count_lbl = Gtk.Label(label="")
        self.count_lbl.set_name("count-lbl")
        footer.pack_start(self.count_lbl, True, True, 0)

        add_item_btn = Gtk.Button(label="+ Add")
        add_item_btn.set_name("add-item-btn")
        add_item_btn.connect("clicked", lambda b: self._toggle_add_panel())
        footer.pack_end(add_item_btn, False, False, 0)

        clear_btn = Gtk.Button(label="Clear Unpinned")
        clear_btn.set_name("clear-btn")
        clear_btn.connect("clicked", lambda b: self._clear_unpinned())
        footer.pack_end(clear_btn, False, False, 0)

        root.pack_start(footer, False, False, 0)

    def _build_tray(self):
        try:
            self.tray = Gtk.StatusIcon()
            self.tray.set_from_icon_name("edit-paste")
            self.tray.set_tooltip_text("Clipboard Manager  (Win+V)")
            self.tray.connect("activate", lambda i: self._toggle())
            self.tray.connect("popup-menu", self._tray_menu)
            self.tray.set_visible(True)
        except Exception:
            pass

    def _tray_menu(self, icon, button, time):
        menu = Gtk.Menu()
        show_item = Gtk.MenuItem(label="Show History")
        show_item.connect("activate", lambda i: self._show())
        menu.append(show_item)
        menu.append(Gtk.SeparatorMenuItem())
        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", lambda i: Gtk.main_quit())
        menu.append(quit_item)
        menu.show_all()
        menu.popup(None, None, None, None, button, time)

    # ── list rendering ───────────────────────────────────────────────────────

    def _refresh(self, filter_text=""):
        for child in self.listbox.get_children():
            self.listbox.remove(child)

        pinned = [h for h in self.history if h['pinned']]
        unpinned = [h for h in self.history if not h['pinned']]
        ft = filter_text.lower()
        count = 0
        for item in pinned + unpinned:
            if ft in item['text'].lower():
                self._add_row(item)
                count += 1

        self.count_lbl.set_text(f"{count} item{'s' if count != 1 else ''}")
        self.listbox.show_all()

    def _add_row(self, item):
        row = Gtk.ListBoxRow()
        row.item = item

        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        box.get_style_context().add_class("item-box")
        if item['pinned']:
            box.get_style_context().add_class("pinned-box")

        # Detect multiline vs single
        lines = item['text'].splitlines()
        if len(lines) > 1:
            preview = lines[0].strip() + f"  [+{len(lines)-1} lines]"
        else:
            preview = item['text']
        if len(preview) > 95:
            preview = preview[:95] + "..."

        lbl = Gtk.Label(label=preview)
        lbl.get_style_context().add_class("item-text")
        lbl.set_xalign(0)
        lbl.set_ellipsize(3)
        lbl.set_max_width_chars(75)
        box.pack_start(lbl, True, True, 0)

        del_btn = Gtk.Button(label="x")
        del_btn.get_style_context().add_class("del-btn")
        del_btn.connect("clicked", lambda b, it=item: self._delete(it))
        box.pack_end(del_btn, False, False, 0)

        edit_btn = Gtk.Button(label="Edit")
        edit_btn.get_style_context().add_class("edit-btn")
        edit_btn.connect("clicked", lambda b, it=item: self._open_edit_dialog(it))
        box.pack_end(edit_btn, False, False, 0)

        paste_btn = Gtk.Button(label="Paste")
        paste_btn.get_style_context().add_class("paste-btn")
        paste_btn.connect("clicked", lambda b, it=item: self._copy_and_paste(it))
        box.pack_end(paste_btn, False, False, 0)

        copy_btn = Gtk.Button(label="Copy")
        copy_btn.get_style_context().add_class("copy-btn")
        copy_btn.connect("clicked", lambda b, it=item, cb=copy_btn: self._copy_only(it, cb))
        box.pack_end(copy_btn, False, False, 0)

        pin_lbl = "Unpin" if item['pinned'] else "Pin"
        pin_btn = Gtk.Button(label=pin_lbl)
        pin_btn.get_style_context().add_class("pin-btn")
        if item['pinned']:
            pin_btn.get_style_context().add_class("is-pinned")
        pin_btn.connect("clicked", lambda b, it=item: self._toggle_pin(it))
        box.pack_end(pin_btn, False, False, 0)

        row.add(box)
        self.listbox.add(row)

    # ── row actions ──────────────────────────────────────────────────────────

    def _on_activate(self, lb, row):
        # Row click or Enter = copy only, window stays open
        if not hasattr(row, 'item'):
            return
        # Find the copy button in this row and flash it
        box = row.get_child()
        copy_btn = None
        for child in box.get_children():
            if isinstance(child, Gtk.Button) and child.get_label() == "Copy":
                copy_btn = child
                break
        self._copy_only(row.item, copy_btn)

    def _copy_only(self, item, btn=None):
        text = item['text']
        self.clipboard.set_text(text, -1)
        self.clipboard.store()
        self.last_text = text
        # Flash button label to "Copied!" briefly
        if btn:
            btn.set_label("Copied!")
            btn.get_style_context().add_class("copied")
            GLib.timeout_add(1200, lambda: self._reset_copy_btn(btn))

    def _reset_copy_btn(self, btn):
        btn.set_label("Copy")
        btn.get_style_context().remove_class("copied")
        return False

    def _copy_and_paste(self, item):
        text = item['text']
        self.clipboard.set_text(text, -1)
        self.clipboard.store()
        self.last_text = text
        self._hide()
        GLib.timeout_add(180, self._paste)

    def _paste(self):
        try:
            subprocess.Popen(
                ['xdotool', 'key', '--clearmodifiers', 'ctrl+v'],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except Exception:
            pass
        return False

    # ── add panel ────────────────────────────────────────────────────────────

    def _toggle_add_panel(self):
        if self.add_panel.get_visible():
            self._hide_add_panel()
        else:
            self._show_add_panel()

    def _show_add_panel(self):
        self.add_panel.show_all()
        self.add_view.get_buffer().set_text("")
        self.add_view.grab_focus()

    def _hide_add_panel(self):
        self.add_panel.hide()
        self.search.grab_focus()

    def _on_add_text_changed(self, buf):
        has_text = buf.get_char_count() > 0
        self.save_btn.set_sensitive(has_text)

    def _save_new_item(self):
        buf = self.add_view.get_buffer()
        text = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), False).strip()
        if not text:
            return
        self._push(text)
        self._hide_add_panel()
        self._refresh(self.search.get_text())

    # ── edit dialog ──────────────────────────────────────────────────────────

    def _open_edit_dialog(self, item):
        self._dialog_open = True
        dialog = Gtk.Dialog(title="Edit Item", transient_for=self.win, modal=True)
        dialog.set_default_size(440, 260)
        dialog.set_keep_above(True)

        area = dialog.get_content_area()
        area.set_spacing(8)
        area.set_margin_start(12)
        area.set_margin_end(12)
        area.set_margin_top(10)
        area.set_margin_bottom(6)

        lbl = Gtk.Label(label="Edit clipboard item:")
        lbl.set_xalign(0)
        area.pack_start(lbl, False, False, 0)

        sw = Gtk.ScrolledWindow()
        sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        sw.set_min_content_height(140)
        tv = Gtk.TextView()
        tv.set_name("add-view")
        tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        tv.get_buffer().set_text(item['text'])
        sw.add(tv)
        area.pack_start(sw, True, True, 0)

        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        save_btn = dialog.add_button("Save", Gtk.ResponseType.OK)
        save_btn.get_style_context().add_class("suggested-action")

        dialog.show_all()
        response = dialog.run()

        if response == Gtk.ResponseType.OK:
            buf = tv.get_buffer()
            new_text = buf.get_text(
                buf.get_start_iter(), buf.get_end_iter(), False
            ).strip()
            if new_text and new_text != item['text']:
                item['text'] = new_text
                self._save()
                self._refresh(self.search.get_text())

        dialog.destroy()
        self._dialog_open = False

    def _toggle_pin(self, item):
        item['pinned'] = not item['pinned']
        self._save()
        self._refresh(self.search.get_text())

    def _delete(self, item):
        self.history = [h for h in self.history if h is not item]
        self._save()
        self._refresh(self.search.get_text())

    def _clear_unpinned(self):
        self.history = [h for h in self.history if h['pinned']]
        self._save()
        self._refresh()

    def _on_key(self, win, event):
        if event.keyval == Gdk.KEY_Escape:
            self._hide()
        elif event.keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            row = self.listbox.get_selected_row()
            if row and hasattr(row, 'item'):
                self._copy_and_paste(row.item)
        return False

    # ── show / hide / toggle ─────────────────────────────────────────────────

    def _show(self):
        GLib.idle_add(self.__do_show)

    def __do_show(self):
        self._refresh()

        display = Gdk.Display.get_default()
        seat = display.get_default_seat()
        pointer = seat.get_pointer()
        screen, cx, cy = pointer.get_position()
        sw, sh = screen.get_width(), screen.get_height()
        w, h = 480, 560
        wx = _clamp(cx - w // 2, 0, sw - w)
        wy = _clamp(cy - 10, 0, sh - h)
        self.win.move(wx, wy)

        self.win.show_all()
        self.add_panel.hide()  # always start with add panel closed
        self.win.present()
        self.search.grab_focus()
        self.visible = True
        return False

    def _hide(self):
        self.win.hide()
        self.visible = False
        self.search.set_text("")

    def _toggle(self):
        if self.visible:
            GLib.idle_add(lambda: self._hide() or False)
        else:
            self._show()

    # ── global hotkey ─────────────────────────────────────────────────────────

    def _hotkey_loop(self):
        try:
            from pynput import keyboard as kb

            held = set()

            SUPER_KEYS = {kb.Key.cmd, kb.Key.cmd_l, kb.Key.cmd_r}
            try:
                SUPER_KEYS.add(kb.Key.super_l)
                SUPER_KEYS.add(kb.Key.super_r)
            except AttributeError:
                pass

            def on_press(key):
                held.add(key)
                super_down = bool(held & SUPER_KEYS)
                try:
                    v_down = key.char == 'v'
                except AttributeError:
                    v_down = False
                if super_down and v_down:
                    self._toggle()

            def on_release(key):
                held.discard(key)

            with kb.Listener(on_press=on_press, on_release=on_release) as lst:
                lst.join()

        except Exception as e:
            print(f"[clipboard-manager] hotkey error: {e}", file=sys.stderr)

    # ── main ──────────────────────────────────────────────────────────────────

    def run(self):
        signal.signal(signal.SIGINT, lambda *_: Gtk.main_quit())
        signal.signal(signal.SIGTERM, lambda *_: Gtk.main_quit())
        Gtk.main()


if __name__ == '__main__':
    ClipboardManager().run()
